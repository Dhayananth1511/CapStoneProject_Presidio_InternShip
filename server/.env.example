# =======================================================
# SERVER CONFIGURATION
# =======================================================
PORT=5000
NODE_ENV=development

# =======================================================
# MONGODB ATLAS
# =======================================================
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/travel_planner

# =======================================================
# JWT SECRETS
# =======================================================
JWT_ACCESS_SECRET=your_jwt_access_token_secret_security_key
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_security_key
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# =======================================================
# REDIS (Optional)
# =======================================================
REDIS_URL=redis://localhost:6379

# =======================================================
# GROQ LLM API
# =======================================================
GROQ_API_KEY=gsk_your_primary_groq_api_key
GROQ_API_KEY_2=gsk_optional_groq_api_key_2
GROQ_API_KEY_3=gsk_optional_groq_api_key_3
GROQ_API_KEY_4=gsk_optional_groq_api_key_4
GROQ_API_KEY_5=gsk_optional_groq_api_key_5

# =======================================================
# GOOGLE APIS — Geocoding / Maps
# =======================================================
GOOGLE_MAPS_API_KEY=AIzaSy_your_google_maps_api_key

# =======================================================
# GEOAPIFY API — Geocoding, Routing, and Places
# =======================================================
GEOAPIFY_API_KEY=your_geoapify_api_key_here

# =======================================================
# HOTELBEDS API — Real Hotel Inventory / Rates
# =======================================================
HOTELBEDS_API_KEY=your_hotelbeds_api_key_here
HOTELBEDS_API_SECRET=your_hotelbeds_api_secret_here
HOTELBEDS_BASE_URL=https://api.test.hotelbeds.com

# =======================================================
# ADDITIONAL PARTNER API KEYS
# =======================================================
ACTIVITY_API_KEY=your_activity_api_key_here
TRANSFERS_API_KEY=your_transfers_api_key_here

# =======================================================
# GOOGLE OAUTH CALENDAR INTEGRATION
# =======================================================
GOOGLE_CALENDAR_CLIENT_ID=your_google_calendar_client_id.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_calendar_client_secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# =======================================================
# AVIATIONSTACK API — Free Flight Schedules
# =======================================================
AVIATIONSTACK_API_KEY=your_aviationstack_api_key_here

# =======================================================
# OPENWEATHER API (Optional)
# =======================================================
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# =======================================================
# FRONTEND CORS WHitelist
# =======================================================
CLIENT_URL=http://localhost:5173
